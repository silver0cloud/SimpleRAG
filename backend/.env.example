# Copy this file to `.env` in the same folder (backend/.env) and fill in
# what you want. Everything here is OPTIONAL — you can also just paste
# keys directly into the app's sidebar each time you run it.

# Lets you skip pasting a NewsAPI key into the UI every time.
# Get one free at https://newsapi.org/register
NEWS_API_KEY=

# Lets you skip pasting a Gemini key into the UI every time.
# Get one free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Comma-separated list of origins allowed to call this API (CORS).
# Defaults to the Vite dev server ports — you usually don't need to touch
# this unless you're deploying somewhere with a different frontend origin.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
